# Copy to .env and fill in.

# Kaggle API token for downloading the IEEE-CIS dataset.
# https://www.kaggle.com/settings -> API
KAGGLE_API_TOKEN=

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5500
MLFLOW_EXPERIMENT_NAME=argus
ARGUS_MODEL_NAME=argus_fraud_classifier

# Redpanda / Kafka. Three brokers by default; keep only the first for "make up-single".
KAFKA_BOOTSTRAP_SERVERS=localhost:19092,localhost:29092,localhost:39092

# Redis (Feast online store). The Feast connection string defaults to
# REDIS_HOST:REDIS_PORT; set ARGUS_REDIS_CONNECTION to override it directly.
REDIS_HOST=localhost
REDIS_PORT=6379

# Bearer token /predict requires, shared by the consumer that calls it. Unset disables auth
# (local only); the compose stack falls back to a non-secret dev key so auth runs out of the box.
SERVING_API_KEY=
