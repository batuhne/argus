# Template for the monitoring artifact-store credentials. Copy to monitor-secret.env
# (gitignored) and create the in-cluster Secret out of band, so no credential value is
# ever committed:
#
#   kubectl -n argus create secret generic argus-monitoring-secrets \
#     --from-env-file=infra/k8s/base/monitor-secret.env
#
# The monitor only reads the baseline artifact from MLflow/MinIO; it never calls /predict,
# so it gets the artifact-store credentials and not the serving bearer token. Local dev
# (MinIO) defaults are minioadmin / minioadmin; a cloud cluster supplies these via IRSA or
# an external secrets manager.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
