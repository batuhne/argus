# Template for the serving artifact-store credentials. Copy to secret.env
# (gitignored) and create the in-cluster Secret out of band, so no credential
# value is ever committed:
#
#   kubectl -n argus create secret generic argus-serving-secrets \
#     --from-env-file=infra/k8s/base/secret.env
#
# Local dev (MinIO) defaults are minioadmin / minioadmin. In a cloud cluster the
# Secret is supplied by an external secrets manager (IRSA, External Secrets).
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
